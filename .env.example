# DeepSeek API 配置
DEEPSEEK_API_KEY=sk-your-api-key-here
DEEPSEEK_API_URL=https://api.deepseek.com/chat/completions
DEEPSEEK_MODEL=deepseek-chat

# 百度智能云 OCR 配置（可选，配置后优先使用百度OCR，识别准确率更高）
# 获取方式：登录 https://cloud.baidu.com -> 文字识别 -> 创建应用 -> 获取 API Key 和 Secret Key
BAIDU_OCR_API_KEY=
BAIDU_OCR_SECRET_KEY=

# 服务端口
PORT=3000
